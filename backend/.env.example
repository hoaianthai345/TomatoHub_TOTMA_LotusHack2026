# FastAPI environment
APP_ENV=local
SECRET_KEY=replace-with-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=12345678
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BACKEND_CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# Local PostgreSQL connection (development)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/lotushack

# Aiven PostgreSQL connection (cloud)
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg2://avnadmin:<url-encoded-password>@<service-host>:<service-port>/<database>?sslmode=require
# BACKEND_CORS_ORIGINS=https://your-frontend.vercel.app
# BACKEND_CORS_ALLOW_ORIGIN_REGEX=
